# DGX Spark observability stack — environment variables.
# Copy to .env and edit values. .env is gitignored.

# Timezone used by Alertmanager for mute_time_intervals.
TZ=UTC

# Bind address for host-exposed UIs.
# - 127.0.0.1: localhost only, requires SSH port-forwarding for remote access
# - <tailscale ip>: accessible to your tailnet (recommended if Tailscale installed)
BIND_ADDRESS=127.0.0.1

# Grafana admin credentials. Change before first start.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme

# ntfy topic name. THIS IS YOUR ONLY ACCESS CONTROL — anyone who knows this
# string can read AND publish to your alert channel. Treat it like a secret:
# use a long, random, unguessable string (e.g. `openssl rand -hex 16`).
# Topic names are part of public ntfy.sh-compatible URLs and are NOT
# protected by the Grafana admin password or BIND_ADDRESS.
NTFY_TOPIC=CHANGE_ME_TO_AN_UNGUESSABLE_STRING

# Retention.
PROMETHEUS_RETENTION_DAYS=180
LOKI_RETENTION_DAYS=90

# DCGM exporter image. Pin to a known-good tag.
DCGM_EXPORTER_IMAGE=nvcr.io/nvidia/k8s/dcgm-exporter:4.1.1-4.0.4-ubuntu22.04
